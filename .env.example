APP_NAME=PeopleOps Intelligence Console

OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
HR_POLICY_PDF=data/员工手册测试版.pdf
CHROMA_PERSIST_DIR=var/chroma/policy
RAG_MANIFEST_PATH=var/chroma/policy/manifest.json
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=40
RAG_TOP_K=3
RAG_MIN_PASS_RATE=1.0
RAG_MIN_KEYWORD_COVERAGE=0.5
RAG_MIN_CITATION_CORRECTNESS=0.8

ENTERPRISE_MODE=false
REQUIRE_ACCESS_PASSWORD=false
ACCESS_PASSWORD=
ACCESS_PASSWORD_MIN_LENGTH=12
TRUSTED_SSO_ENABLED=false
TRUSTED_SSO_USER_HEADER=X-Authenticated-User
TRUSTED_SSO_ROLE_HEADER=X-Authenticated-Role
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_HS256_SECRET=
OIDC_ROLE_CLAIM=role
OIDC_DEFAULT_ROLE=viewer
APP_DB_PATH=var/runtime/peopleops.sqlite3
AUDIT_LOG_PATH=var/runtime/audit/events.jsonl
AUDIT_LOG_MAX_BYTES=5000000
AUDIT_HASH_CHAIN_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
DEFAULT_TENANT_ID=default
DEFAULT_ORG_ID=default-org
DEFAULT_DEPARTMENT_ID=peopleops
DATABASE_BACKEND=sqlite
DATABASE_URL=
VECTOR_BACKEND=chroma
VECTOR_STORE_URL=
OBJECT_STORAGE_URI=
POSTGRES_PASSWORD=change_me_in_production
MINIO_ROOT_USER=peopleops
MINIO_ROOT_PASSWORD=change_me_in_production
APPROVAL_REQUIRED_ACTIONS=send_email,calendar_invite,ats_stage_change,offer_draft,rejection_draft
CONFIGURED_CONNECTOR_ENV=
EMAIL_DRAFT_DIR=var/runtime/email_drafts
CALENDAR_DIR=var/runtime/calendar
ATS_EXPORT_DIR=var/runtime/ats_exports
TOOL_EXECUTION_MODE=local
TOOL_DEFAULT_TIMEOUT_SECONDS=20
TOOL_DEFAULT_RETRIES=1

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
