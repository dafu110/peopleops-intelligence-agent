{
  "name": "PeopleOps Intelligence Console",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "backend/api.py",
        "frontend/app/page.tsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f backend/requirements.txt ] && pip3 install --user -r backend/requirements.txt; corepack enable; cd frontend && pnpm install --frozen-lockfile; echo 'Packages installed and requirements met'",
  "postAttachCommand": {
    "api": "cd backend && python -m uvicorn api:app --host 0.0.0.0 --port 8000",
    "web": "cd frontend && pnpm dev --hostname 0.0.0.0 --port 3000"
  },
  "portsAttributes": {
    "3000": {
      "label": "Web Console",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "FastAPI",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    3000,
    8000
  ]
}
